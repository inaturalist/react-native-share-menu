{
  "name": "react-native-share-menu",
  "description": "Add your app as a target for sharing from other apps and write iOS Share Extensions in React Native.",
  "version": "7.1.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meedan/react-native-share-menu.git"
  },
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!lib/typescript/example",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "typescript": "tsc --noEmit",
    "lint": "eslint",
    "prepare": "bob build",
    "release": "release-it",
    "example": "yarn workspace example"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.12.0",
  "keywords": [
    "react-component",
    "react-native",
    "android",
    "ios",
    "share",
    "share-extension",
    "custom-view"
  ],
  "author": {
    "name": "Meedan",
    "email": "hello@meedan.com"
  },
  "homepage": "https://github.com/meedan/react-native-share-menu",
  "license": "MIT",
  "readmeFilename": "README.md",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@react-native/babel-preset": "0.83.9",
    "@react-native/eslint-config": "0.83.9",
    "@react-native/typescript-config": "0.83.9",
    "@release-it/conventional-changelog": "^9.0.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^28.1.1",
    "pod-install": "^0.1.0",
    "prettier": "^3.0.3",
    "react": "19.2.0",
    "react-native": "0.83.9",
    "react-native-builder-bob": "^0.40.17",
    "react-native-monorepo-config": "^0.3.1",
    "release-it": "^17.10.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=19.1.0",
    "react-native": ">=0.81.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
